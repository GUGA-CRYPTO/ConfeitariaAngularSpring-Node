Banco de Dados para testar a aplicação

DROP DATABASE IF EXISTS aura_db;
CREATE DATABASE aura_db;
USE aura_db;

CREATE TABLE usuarios (
  id BIGINT PRIMARY KEY AUTO_INCREMENT,
  nome VARCHAR(120) NOT NULL,
  email VARCHAR(160) NOT NULL,
  usuario VARCHAR(60) NOT NULL UNIQUE,
  senha VARCHAR(64) NOT NULL,
  tipo_usuario VARCHAR(30) DEFAULT 'admin',
  data_cadastro DATETIME DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE produtos (
  id BIGINT PRIMARY KEY AUTO_INCREMENT,
  nome VARCHAR(150) NOT NULL,
  descricao TEXT,
  categoria VARCHAR(50),
  preco DECIMAL(10,2) NOT NULL,
  estoque INT DEFAULT 0,
  ingredientes TEXT,
  emoji VARCHAR(10),
  destaque BOOLEAN DEFAULT FALSE,
  badge VARCHAR(50),
  status VARCHAR(30) DEFAULT 'Ativo',
  imagem VARCHAR(255),
  data_cadastro DATETIME DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE vendas (
  id BIGINT PRIMARY KEY AUTO_INCREMENT,
  usuario_id BIGINT,
  cliente_nome VARCHAR(150),
  forma_pagamento VARCHAR(50),
  observacao TEXT,
  desconto DECIMAL(10,2) DEFAULT 0,
  subtotal DECIMAL(10,2) DEFAULT 0,
  valor_total DECIMAL(10,2) DEFAULT 0,
  data_venda DATETIME DEFAULT CURRENT_TIMESTAMP,
  status VARCHAR(30) DEFAULT 'Concluída',
  FOREIGN KEY (usuario_id) REFERENCES usuarios(id)
);

CREATE TABLE venda_itens (
  id BIGINT PRIMARY KEY AUTO_INCREMENT,
  venda_id BIGINT NOT NULL,
  produto_id BIGINT NOT NULL,
  nome VARCHAR(150), -- Coluna adicionada para armazenar o nome do produto
  quantidade INT NOT NULL,
  preco_unitario DECIMAL(10,2) NOT NULL,
  subtotal_item DECIMAL(10,2) DEFAULT 0,
  FOREIGN KEY (venda_id) REFERENCES vendas(id) ON DELETE CASCADE,
  FOREIGN KEY (produto_id) REFERENCES produtos(id)
);

CREATE TABLE despesas (
  id BIGINT PRIMARY KEY AUTO_INCREMENT,
  usuario_id BIGINT,
  descricao VARCHAR(255) NOT NULL,
  categoria VARCHAR(50),
  tipo VARCHAR(50),
  valor DECIMAL(10,2) NOT NULL,
  data_despesa DATE NOT NULL,
  status VARCHAR(30) DEFAULT 'Pago',
  data_registro DATETIME DEFAULT CURRENT_TIMESTAMP,
  criado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY (usuario_id) REFERENCES usuarios(id)
);

