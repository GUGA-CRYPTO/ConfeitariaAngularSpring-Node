{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "aura-angular": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/aura-angular",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": [{"glob":"**/*","input":"public"}],
            "styles": ["src/styles.css"]
          },
          "configurations": {
            "production": {"optimization": true, "extractLicenses": true, "sourceMap": false}
          }
        },
        "serve": {"builder": "@angular/build:dev-server", "options": {"buildTarget": "aura-angular:build"}}
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
